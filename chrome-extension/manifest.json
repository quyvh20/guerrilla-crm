{
  "manifest_version": 3,
  "name": "Guerrilla CRM Multi-Channel",
  "version": "1.1",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "*://chat.zalo.me/*",
    "*://www.messenger.com/*",
    "*://*.facebook.com/*",
    "*://web.whatsapp.com/*",
    "http://localhost:8787/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://chat.zalo.me/*",
        "*://www.messenger.com/*",
        "*://*.facebook.com/*",
        "*://web.whatsapp.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
